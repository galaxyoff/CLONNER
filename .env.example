# Variáveis de Ambiente - Configure antes de production
# Copie este arquivo para .env e configure os valores

# Obrigatório em produção - Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Debug mode (False em produção)
FLASK_DEBUG=False

# Rate limit (requisições por minuto por IP)
RATE_LIMIT=100 per minute

# Porta do servidor
PORT=5000

# Domínio (para produção com HTTPS)
# DOMAIN=seu-dominio.com

